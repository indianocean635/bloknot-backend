generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  role        String   @default("owner") // OWNER | STAFF | SUPERADMIN
  businessId  String?
  createdAt   DateTime @default(now())

  isPaying     Boolean  @default(false)
  totalPaid    Int      @default(0)
  nextBillingAt DateTime?

  business     Business? @relation("BusinessOwner", fields: [businessId], references: [id])
  staffMembers Staff[]
  loginTokens LoginToken[]
}
model Service {
  id         Int       @id @default(autoincrement())
  name       String
  duration   Int
  price      Int
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  appointments Appointment[]
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services   Service[]
  createdAt  DateTime  @default(now())
}

model Master {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  role      String   @default("MASTER")
  avatarUrl String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  appointments Appointment[]
}

model WorkPhoto {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  address   String?
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  appointments Appointment[]
}

model Appointment {
  id            Int      @id @default(autoincrement())
  customerName  String
  customerPhone String?
  startsAt      DateTime
  endsAt        DateTime
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  priceAtBooking Int?

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id])

  staffId Int
  staff   Master @relation(fields: [staffId], references: [id])

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
}

model Business {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())

  owner     User       @relation("BusinessOwner", fields: [ownerId], references: [id])
  users     User[]
  staff     Staff[]
  services  Service[]
  categories Category[]
  masters   Master[]
  workPhotos WorkPhoto[]
  branches  Branch[]
  appointments Appointment[]
}

model StaffInvite {
  id        String   @id @default(uuid())
  email     String
  businessId String
  status    String   @default("pending") // pending | accepted
  createdAt DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Staff {
  id         String   @id @default(uuid())
  name       String
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LoginToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
}
