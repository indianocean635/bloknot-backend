# Bloknot backend environment
# Copy to .env and fill values

# Server
PORT=3001
BASE_URL=https://bloknotservis.ru

# Paths (optional)
# By default backend serves static frontend from ./public and stores uploads in ./uploads
# FRONTEND_PATH=/var/www/bloknot/frontend
# UPLOADS_PATH=/var/www/bloknot/uploads

# Database
DATABASE_URL=postgresql://bloknot_user:bloknot_password@127.0.0.1:5432/bloknot?schema=public

# CORS (optional)
# If frontend and backend are on the same domain, leave empty.
# CORS_ORIGIN=https://bloknotservis.ru

# SMTP (optional, for real email sending)
# SMTP_HOST=smtp.your-provider.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Bloknot <no-reply@bloknotservis.ru>"

# S3 (Selectel) for file storage
S3_REGION=ru-central1
S3_ENDPOINT=https://s3.storage.selcloud.ru
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=bloknot-uploads

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_PROXY=http://login:password@ip:port
WHATSAPP_WEBHOOK_VERIFY_TOKEN=bloknot_whatsapp_verify

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=your-cloudpayments-public-id
CLOUDPAYMENTS_PRIVATE_KEY=your-cloudpayments-private-key
CLOUDPAYMENTS_WEBHOOK_SECRET=your-cloudpayments-webhook-secret

# Subscription Settings
DEFAULT_TRIAL_DAYS=5
MONTHLY_SUBSCRIPTION_PRICE=990
YEARLY_SUBSCRIPTION_PRICE=9900
